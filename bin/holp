#!/usr/bin/env sh
set -eu
# Resolve symlinks so $0 pointing at a global npm-link target still finds the real repo root.
self=$0
while [ -L "$self" ]; do
  target=$(readlink "$self")
  case "$target" in
    /*) self="$target" ;;
    *)  self="$(dirname -- "$self")/$target" ;;
  esac
done
repo_root=$(CDPATH= cd -- "$(dirname -- "$self")/.." && pwd)
exec "$repo_root/node_modules/.bin/tsx" "$repo_root/consumers/harness-workspace/holp.ts" "$@"
